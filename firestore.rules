rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Match any document in the 'entries' collection
    match /entries/{entryId} {
      // Users can only read, create, update, and delete their own data
      allow read, write: if request.auth != null && request.auth.uid == resource.data.createdBy;
      
      // Allow creation only if they assign themselves as the creator
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy;
    }
  }
}
